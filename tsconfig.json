{
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "bundler",
        "target": "ES2020",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "strict": false,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "experimentalDecorators": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "noEmit": true,
        "sourceMap": true,
        "types": ["vite/client"]
    },
    "include": ["src/**/*.ts", "vite.config.ts"],
    "exclude": ["node_modules", "dist"]
}
